# Round 2 evidence is authenticated byte-for-byte by MANIFEST.sha256.
# Keep checkout bytes stable when a consumer has core.autocrlf enabled.
evidence/round2/** text eol=lf

# Keep Round 3 evidence checkout bytes stable; its manifest records digests.
evidence/round3/** text eol=lf

# Preserve the Base64 transport and manifest byte identity for the v5 static-workflow boundary record.
evidence/static-workflow-v5-pr25/** text eol=lf
# The raw unified diff intentionally retains blank context lines that begin with one space.
evidence/static-workflow-v5-pr25/candidate.diff -whitespace
